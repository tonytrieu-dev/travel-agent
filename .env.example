# ── Travel Agent — environment configuration ─────────────────────────────────
# Copy to `.env` and fill in the free API keys. Nothing here requires a credit card.

# Groq — free tier, generous daily limits (1K requests/day on llama-3.3-70b-versatile).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# SearchApi.io Google Flights — 100 free searches, no card.
# https://www.searchapi.io/
SEARCHAPI_API_KEY=your-searchapi-key

# Tavily — AI-agent web search, 1,000 free credits/month, no card.
# https://www.tavily.com/
TAVILY_API_KEY=your-tavily-key

# PostgreSQL. The async URL is used by the app (asyncpg); DBOS derives a sync URL from it.
# Local Homebrew default (peer auth, your macOS username, no password):
DATABASE_URL=postgresql+asyncpg://tony@localhost:5432/travel_agent

# Flight-API mode. `true` (default) calls SearchApi live — use for the real demo.
# `false` replays recorded-REAL cassettes (captured payloads) to protect the 100-search
# quota during dev reloads / tests / evals. It NEVER fabricates data.
USE_LIVE_FLIGHT_API=true

# Frontend origin allowed by CORS (no wildcard).
FRONTEND_ORIGIN=http://localhost:5173
